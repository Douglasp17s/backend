# Django
DJANGO_SECRET_KEY=django-insecure-dev-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (MISMA que NestJS backend!)
DB_NAME=transit_ai
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Celery / Redis (opcional, para entrenamientos asincronos)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000,http://localhost:8000

# NestJS Backend (para obtener datos de entrenamiento)
NESTJS_BACKEND_URL=http://localhost:4000
