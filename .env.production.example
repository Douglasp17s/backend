# Production Environment Variables
# IMPORTANTE: Cambiar TODOS los valores antes de desplegar a producción

# Docker Registry
DOCKER_REGISTRY=your-registry.com
VERSION=1.0.0

# Database
DB_USER=transit_prod_user
DB_PASSWORD=change-me-to-a-very-secure-password
DB_NAME=transit_ai_prod

# Redis
REDIS_PASSWORD=change-me-to-a-very-secure-password

# JWT
JWT_SECRET=generate-with-openssl-rand-base64-32-change-this-value
JWT_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=7d

# Stripe
STRIPE_SECRET_KEY=sk_live_your_production_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_production_key

# Blockchain
HARDHAT_RPC=https://polygon-rpc.com  # O tu nodo de producción
HARDHAT_CHAIN_ID=137  # Polygon mainnet

# Frontend
NEXT_PUBLIC_API_URL=https://api.transit-ai.com
NEXT_PUBLIC_MAPS_API_KEY=your_google_maps_production_key

# Node
NODE_ENV=production

# Logging
LOG_LEVEL=warn

# Security
CORS_ORIGINS=https://transit-ai.com,https://www.transit-ai.com
