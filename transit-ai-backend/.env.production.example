# ════════════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE PRODUCCIÓN - Transit AI Backend
# ════════════════════════════════════════════════════════════════════════════════

# AMBIENTE
NODE_ENV=production
PORT=4000

# ────────────────────────────────────────────────────────────────────────────────
# BASE DE DATOS (RDS PostgreSQL en AWS)
# ────────────────────────────────────────────────────────────────────────────────
# Formato: postgresql://usuario:contraseña@host:5432/nomina_db
# Ejemplo: postgresql://admin:MySecurePass123!@transit-ai-db.abc123.us-east-1.rds.amazonaws.com:5432/transit_ai_prod
DATABASE_URL=postgresql://admin:YOUR_SECURE_PASSWORD_HERE@transit-ai-db.abc123.us-east-1.rds.amazonaws.com:5432/transit_ai_prod

# ────────────────────────────────────────────────────────────────────────────────
# JWT
# ────────────────────────────────────────────────────────────────────────────────
JWT_SECRET=YOUR_SUPER_SECURE_JWT_SECRET_MIN_32_CHARS_LONG_HERE
JWT_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=7d

# ────────────────────────────────────────────────────────────────────────────────
# BLOCKCHAIN (Hardhat / Ethereum)
# ────────────────────────────────────────────────────────────────────────────────
BLOCKCHAIN_RPC_URL=http://localhost:8545
BLOCKCHAIN_NETWORK=localhost
BLOCKCHAIN_OWNER_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb476caded64645dd5067ada1f80e
WALLET_ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_FOR_WALLETS

# ────────────────────────────────────────────────────────────────────────────────
# STRIPE (Pagos)
# ────────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLIC_KEY
STRIPE_CURRENCY=BOB
BILLETERA_QR_SECRET=YOUR_QR_SECRET_KEY

# ────────────────────────────────────────────────────────────────────────────────
# FRONTEND
# ────────────────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://transit-ai.com

# ────────────────────────────────────────────────────────────────────────────────
# OPCIONALES
# ────────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
DEBUG_SQL=false
REQUEST_TIMEOUT=30000
RATE_LIMIT_MAX=100
ABONO_VIAJES=40
ABONO_DIAS=30



Endpoint: erp-postgres.cmayrqiok31.us-east-1.rds.amazonaws.com
Puerto: 5432
Usuario: erp_user
Base de datos: postgres (la BD por defecto)
