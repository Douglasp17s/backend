# ───────────────────────────────────────────────────────────────────────────
# Archivo de ejemplo de variables de entorno para Transit AI Backend (NestJS)
#
# INSTRUCCIONES:
# 1. Copia este archivo a .env en la raíz del proyecto
# 2. Reemplaza los valores placeholder con valores reales
# 3. NUNCA commits .env al repositorio
# 4. NO compartas .env en redes públicas
# ───────────────────────────────────────────────────────────────────────────

# ─── APLICACIÓN ──────────────────────────────────────────────────────────
# Puerto en el que se ejecutará el servidor NestJS
NODE_ENV=development
PORT=4000

# ─── BASE DE DATOS ──────────────────────────────────────────────────────
# PostgreSQL connection string
# Formato: postgresql://usuario:contraseña@host:puerto/base_datos
DATABASE_URL=postgresql://postgres:contraseña_segura@localhost:5432/transit_ai_db

# ─── AUTENTICACIÓN JWT ──────────────────────────────────────────────────
# Secreto para firmar tokens JWT (mínimo 32 caracteres aleatorios)
JWT_SECRET=tu_secreto_jwt_muy_largo_y_seguro_aqui
# Expiración del access token
JWT_EXPIRATION=15m
# Expiración del refresh token
REFRESH_TOKEN_EXPIRATION=7d

# ─── BLOCKCHAIN (Billetera / Pagos On-Chain) ────────────────────────────
# URL RPC del nodo Ethereum/Hardhat
# Desarrollo local: http://127.0.0.1:8545
# Testnet: https://sepolia.infura.io/v3/tu_infura_key
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
# Red blockchain
# Valores: localhost, sepolia, mainnet
BLOCKCHAIN_NETWORK=localhost
# Clave privada del owner del contrato (solo para desarrollo)
# IMPORTANTE: En producción, usar solo para deployar contracts, no para transacciones
BLOCKCHAIN_OWNER_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# Dirección del contrato de billetera desplegado
BLOCKCHAIN_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ─── CIFRADO DE CLAVES PRIVADAS ─────────────────────────────────────────
# Clave para cifrar las llaves privadas de usuarios (custodial wallet)
# Mínimo 32 caracteres, cambia en producción
WALLET_ENCRYPTION_KEY=tu_clave_cifrado_segura_32_caracteres

# ─── TOKENS QR DE PAGO ──────────────────────────────────────────────────
# Secreto para firmar tokens QR temporales (pago sin contacto)
BILLETERA_QR_SECRET=tu_secreto_qr_aqui

# ─── CONFIGURACIÓN DE ABONO MENSUAL ─────────────────────────────────────
# Cantidad de viajes equivalentes en un pase mensual
ABONO_VIAJES=40
# Días de validez del pase mensual
ABONO_DIAS=30

# ─── STRIPE (Pagos con Tarjeta de Crédito) ──────────────────────────────
# Obtén las claves desde: https://dashboard.stripe.com/test/apikeys
# Clave secreta de Stripe (secreto, nunca en cliente)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Clave publicable de Stripe (puede estar en cliente)
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Código de moneda
STRIPE_CURRENCY=BOB

# ─── URLS PÚBLICAS ──────────────────────────────────────────────────────
# URL del frontend (para CORS y redirecciones)
FRONTEND_URL=http://localhost:3000
# URL del móvil (si es diferente, usa la IP del servidor local)
MOBILE_APP_URL=http://localhost:4000

# ─── LOGGING Y DEBUG ─────────────────────────────────────────────────────
# Nivel de log: debug, info, warn, error
LOG_LEVEL=info
# Habilitar logs detallados de SQL (Prisma)
DEBUG_SQL=false

# ─── CONFIGURACIÓN DE CORREO (OPCIONAL) ──────────────────────────────────
# Para notificaciones por email
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu_email@gmail.com
MAIL_PASS=tu_password_app_google
MAIL_FROM=noreply@transit-ai.local

# ─── CONFIGURACIÓN DE GOOGLE MAPS (OPCIONAL) ────────────────────────────
# Para planificador de rutas y ubicación
GOOGLE_MAPS_API_KEY=tu_api_key_google_maps

# ─── TWILIO (SMS, OPCIONAL) ──────────────────────────────────────────────
# Para notificaciones por SMS a conductores
TWILIO_ACCOUNT_SID=tu_account_sid
TWILIO_AUTH_TOKEN=tu_auth_token
TWILIO_PHONE_NUMBER=+591xxxxxxxxx

# ─── REDIS (OPCIONAL - para caché y sesiones) ───────────────────────────
REDIS_URL=redis://localhost:6379

# ─── TIMEOUT Y RATE LIMITING ────────────────────────────────────────────
# Timeout global para requests (ms)
REQUEST_TIMEOUT=30000
# Máximo de requests por IP en 15 minutos
RATE_LIMIT_MAX=100

# ─── FIREBASE (PUSH NOTIFICATIONS) ────────────────────────────────────────
# Ruta al archivo de credenciales de Firebase Admin SDK
# Obtén el archivo desde: https://console.firebase.google.com → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT=src/firebase-service-account.json

# ─── INTEGRACIÓN CON DJANGO ML SERVICE ───────────────────────────────────
# URL del microservicio de ML (para predicciones)
ML_SERVICE_URL=http://localhost:8000/api
